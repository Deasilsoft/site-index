{
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/site-index",
    "packages/@site-index/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "clean": "npm run clean:install && npm run clean:packages",
    "preclean:install": "rm -rf node_modules package-lock.json",
    "clean:install": "npm install",
    "clean:packages": "npm run clean --workspaces --if-present",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "knip": "knip",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "code-slicer": "^0.4.1",
    "eslint": "^10.2.1",
    "knip": "^6.6.3",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": ">=22"
  }
}
