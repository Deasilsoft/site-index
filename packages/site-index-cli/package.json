{
  "name": "site-index-cli",
  "version": "0.0.0",
  "description": "CLI for site-index pipeline execution and scaffolding.",
  "keywords": [
    "site-index",
    "cli",
    "sitemap",
    "robots",
    "seo"
  ],
  "homepage": "https://github.com/Deasilsoft/site-index/tree/main/packages/site-index-cli",
  "bugs": {
    "url": "https://github.com/Deasilsoft/site-index/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Deasilsoft/site-index.git",
    "directory": "packages/site-index-cli"
  },
  "license": "MIT",
  "author": "Deasilsoft <contact@deasilsoft.com>",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "site-index": "./dist/entrypoint.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "postbuild": "npm run build:bin && npm run build:templates",
    "build:bin": "chmod +x dist/entrypoint.js",
    "build:templates": "mkdir -p dist/domains/scaffold/templates && cp -r src/domains/scaffold/templates/* dist/domains/scaffold/templates/",
    "clean": "rm -rf dist coverage",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "node-plop": "^0.32.3",
    "site-index": "^0.0.0",
    "vite": "^8.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  }
}
